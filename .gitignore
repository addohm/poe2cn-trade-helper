# Cached raw API responses (regenerated by build_dict.py)
tool/raw/

# Build intermediates — the installable userscript (dist/poe2cn-trade.user.js) is
# committed for auto-update; these large derived files are not.
tool/dist/dict.json
tool/dist/dict.runtime.json
tool/dist/report.md

# Client-datamined inputs (regenerated from the WeGame client by the extract
# scripts). Large; not needed by consumers of the userscript.
tool/data/*.json

# OS / editor cruft
Thumbs.db
.DS_Store
